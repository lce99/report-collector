# Core run settings
REPORT_TIMEZONE=Asia/Seoul
REPORT_PAGE_DEPTH=4
MUST_READ_LIMIT=12
RANKING_LIMIT=5
SEND_TELEGRAM=true
SITE_URL=
PDF_TEXT_ENABLED=true
PDF_TEXT_PAGE_LIMIT=8
PDF_TEXT_CHAR_LIMIT=12000
PDF_TEXT_MIN_BODY_CHARS=500

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# OpenAI summary and investment memo enhancement
OPENAI_SUMMARY_ENABLED=false
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
OPENAI_SUMMARY_MAX_REPORTS=8
OPENAI_SUMMARY_MIN_CHARS=180
OPENAI_SUMMARY_CHAR_LIMIT=6000
# OPENAI_REASONING_EFFORT=minimal

# Market data and selection performance tracking
MARKET_DATA_ENABLED=true
MARKET_DATA_SOURCE=naver
MARKET_DATA_MAX_PAGES=8
# 우선 검토 후보 수익률을 비교할 벤치마크 지수 (KOSPI 또는 KOSDAQ)
MARKET_BENCHMARK=KOSPI
# 종목코드가 없는 공식 리포트 보강 매핑 (아카이브에서 자동 학습되므로 보통 비워둬도 됩니다)
# SUBJECT_TICKER_MAP=삼성전자=005930,NAVER=035420

# Priority filters
# Example: 삼성전자,SK하이닉스,한화에어로스페이스
PRIORITY_SUBJECTS=
# Example: 반도체,방산,원자력,로봇
PRIORITY_KEYWORDS=
# true로 두면 필독/텔레그램 목록을 관심 일치 리포트 중심으로 강하게 좁힙니다.
PRIORITY_ONLY=false

# Optional tuning
# REPORT_CATEGORIES=company,industry,economy,invest,market,debenture
# BROKER_PRIORITY=메리츠증권,삼성증권,신한투자증권,한국투자증권,키움증권
